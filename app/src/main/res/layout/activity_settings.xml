<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ustawienia"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BEZPIECZEŃSTWO"
            android:textSize="12sp"
            android:textColor="#90A4AE"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Zmień PIN do aplikacji"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:drawableEnd="@android:drawable/ic_media_play" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Limity transakcyjne"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:drawableEnd="@android:drawable/ic_media_play" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="APLIKACJA"
            android:textSize="12sp"
            android:textColor="#90A4AE"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Język / Language"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Wyloguj"
                    android:textColor="#D32F2F"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>